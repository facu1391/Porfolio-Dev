---
const currentYear = new Date().getFullYear()
---

<footer
  class="container mx-auto mb-10 mt-16 flex w-full justify-center px-4 opacity-80 lg:max-w-4xl md:max-w-2xl"
>
  <div
    class="mx-auto flex w-full max-w-screen-xl flex-col gap-4 rounded-lg border border-black/5 bg-white/40 px-4 py-4 backdrop-blur dark:border-white/10 dark:bg-white/5 md:flex-row md:items-center md:justify-between"
  >
    <span class="text-sm text-zinc-800/90 dark:text-zinc-200/90">
      © {currentYear}
      <a href="#" class="hover:underline">Facundo Núñez</a>.
      Todos los derechos reservados.
    </span>

    <ul
      class="flex flex-wrap items-center gap-4 text-sm font-medium dark:text-white/90"
    >
      <li>
        <a href="/#sobre-mi" class="hover:underline">Sobre mí</a>
      </li>
      <li>
        <a href="/#contacto" class="hover:underline">Contacto</a>
      </li>
    </ul>
  </div>
</footer>
