---
const personalImageAlt = "Facundo Núñez"

import Badge from "../components/Badge.astro"
import LinkedInIcon from "../components/icons/LinkedIn.astro"
import MailIcon from "../components/icons/Mail.astro"
import SocialPill from "../components/SocialPill.astro"
---

<div class="grid items-center gap-10 lg:grid-cols-[1.25fr,0.95fr]">
  <div class="max-w-2xl">
    <div class="mb-5 flex flex-wrap items-center gap-3">
      <img
        class="h-20 w-20 rounded-3xl object-cover shadow-lg ring-1 ring-black/10 dark:ring-white/10"
        src="Perfil.png"
        alt={personalImageAlt}
      />

      <a
        href="https://www.linkedin.com/in/facundo-nu%C3%B1ez-380b9b234/"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center transition hover:scale-[1.02]"
      >
        <Badge>Disponible para trabajar</Badge>
      </a>
    </div>

    <p class="mb-3 text-sm font-medium uppercase tracking-[0.22em] text-yellow-600 dark:text-yellow-300">
      Desarrollador Fullstack en productos reales
    </p>

    <h1 class="max-w-3xl text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl md:text-6xl dark:text-white">
      Construyo software web claro, rápido y listo para producción.
    </h1>

    <p class="mt-6 max-w-2xl text-lg leading-8 text-gray-700 dark:text-gray-300">
      Soy Facundo Núñez, desarrollador Fullstack de La Rioja, Argentina. Trabajo en
      productos para el sector público y privado, con foco en experiencia de usuario,
      rendimiento y soluciones que realmente simplifican una operación.
    </p>

    <div class="mt-8 flex flex-wrap gap-4">
      <a
        href="/#proyectos"
        class="inline-flex items-center justify-center rounded-full bg-gray-950 px-5 py-3 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-black focus:outline-none focus-visible:ring focus-visible:ring-yellow-500/80 focus-visible:ring-offset-2 dark:bg-white dark:text-gray-950 dark:hover:bg-gray-200"
      >
        Ver proyectos destacados
      </a>

      <a
        href="/cv"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-full border border-gray-300 bg-white/80 px-5 py-3 text-sm font-semibold text-gray-900 transition hover:-translate-y-0.5 hover:border-gray-400 hover:bg-white focus:outline-none focus-visible:ring focus-visible:ring-yellow-500/80 focus-visible:ring-offset-2 dark:border-white/15 dark:bg-white/5 dark:text-white dark:hover:bg-white/10"
      >
        Ver CV
      </a>
    </div>

    <ul class="mt-8 grid gap-3 text-sm text-gray-700 sm:grid-cols-3 dark:text-gray-300">
      <li class="rounded-2xl border border-black/5 bg-white/70 px-4 py-3 backdrop-blur dark:border-white/10 dark:bg-white/5">
        +4 años creando productos y sistemas en producción
      </li>
      <li class="rounded-2xl border border-black/5 bg-white/70 px-4 py-3 backdrop-blur dark:border-white/10 dark:bg-white/5">
        Experiencia real en frontend, backend y producto
      </li>
      <li class="rounded-2xl border border-black/5 bg-white/70 px-4 py-3 backdrop-blur dark:border-white/10 dark:bg-white/5">
        Proyectos para equipos, negocios y organismos públicos
      </li>
    </ul>

    <nav class="mt-8 flex flex-wrap gap-4">
      <SocialPill href="mailto:facurael@gmail.com">
        <MailIcon class="size-4" />
        Contacto directo
      </SocialPill>
      <SocialPill href="https://www.linkedin.com/in/facundo-nu%C3%B1ez-380b9b234/">
        <LinkedInIcon class="size-4" />
        LinkedIn
      </SocialPill>
    </nav>
  </div>

  <aside class="relative">
    <div class="absolute inset-0 -z-10 rounded-[2rem] bg-gradient-to-br from-yellow-300/30 via-transparent to-sky-300/20 blur-2xl"></div>

    <div class="overflow-hidden rounded-[2rem] border border-black/5 bg-white/70 p-5 shadow-xl backdrop-blur dark:border-white/10 dark:bg-white/5">
      <img
        src="Perfil12.png"
        alt={personalImageAlt}
        class="h-[320px] w-full rounded-[1.5rem] object-cover object-center"
      />

      <div class="mt-5 grid gap-3 sm:grid-cols-2">
        <div class="rounded-2xl border border-black/5 bg-white/85 px-4 py-4 text-gray-900 dark:border-white/10 dark:bg-slate-900/70 dark:text-white">
          <p class="text-xs uppercase tracking-[0.2em] text-gray-500 dark:text-gray-400">
            Perfil
          </p>
          <p class="mt-2 text-sm font-medium">
            Producto, frontend y backend con foco en uso real.
          </p>
        </div>

        <div class="rounded-2xl border border-black/5 bg-white/85 px-4 py-4 text-gray-900 dark:border-white/10 dark:bg-slate-900/70 dark:text-white">
          <p class="text-xs uppercase tracking-[0.2em] text-gray-500 dark:text-gray-400">
            Stack
          </p>
          <p class="mt-2 text-sm font-medium">
            Next.js, React, TypeScript, NestJS, Python y PostgreSQL
          </p>
        </div>
      </div>
    </div>
  </aside>
</div>
