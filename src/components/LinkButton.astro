---
const { href, target, rel } = Astro.props
---

<a
  href={href}
  target={target}
  rel={rel}
  role="link"
  class="inline-flex max-w-fit items-center justify-center gap-2 rounded-xl border border-gray-600 bg-gray-800 px-3 py-2 text-base text-white transition hover:border-gray-900 hover:bg-gray-800 hover:text-white focus:outline-none focus-visible:outline-none focus-visible:ring focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-yellow-500/80 active:bg-black"
>
  <slot />
</a>
