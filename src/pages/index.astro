---
import Layout from "../layouts/Layout.astro"

import AboutMe from "../components/AboutMe.astro"
import Briefcase from "../components/icons/Briefcase.astro"
import CodeIcon from "../components/icons/Code.astro"
import Experience from "../components/Experience.astro"
import ProfileCheck from "../components/icons/ProfileCheck.astro"
import Projects from "../components/Projects.astro"
import SectionContainer from "../components/SectionContainer.astro"
import Hero from "../components/Hero.astro"
import ContactCTA from "../components/ContactCTA.astro"
---

<Layout
  title="Portfolio de Facundo Núñez | Desarrollador Web Fullstack"
  description="Facundo Núñez desarrolla productos web en producción para equipos y negocios que necesitan soluciones claras, rápidas y mantenibles."
>
  <main class="px-4">
    <SectionContainer class="py-16 md:py-36">
      <Hero />
    </SectionContainer>

    <div class="space-y-24">
      <SectionContainer id="experiencia">
        <h2
          class="mb-6 flex items-center gap-x-3 text-3xl font-semibold text-black/80 dark:text-white"
        >
          <Briefcase class="size-8" />
          Experiencia laboral
        </h2>
        <Experience />
      </SectionContainer>

      <SectionContainer id="proyectos">
        <h2
          class="mb-6 flex items-center gap-x-3 text-3xl font-semibold text-black/80 dark:text-white"
        >
          <CodeIcon class="size-7" />
          Proyectos
        </h2>
        <Projects />
      </SectionContainer>

      <SectionContainer id="sobre-mi">
        <h2
          class="mb-6 flex items-center gap-x-8 text-3xl font-semibold text-black/80 dark:text-white"
        >
          <ProfileCheck class="size-8" />
          Sobre mí
        </h2>
        <AboutMe />
      </SectionContainer>

      <SectionContainer id="contacto" class="pb-8">
        <ContactCTA />
      </SectionContainer>
    </div>
  </main>
</Layout>
